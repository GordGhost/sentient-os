# ─── GitHub (skill publishing) ────────────────────────────────────────────────
# Personal access token with `repo` scope. Used by the publish server action to
# create files / open a pull request in your skills repository.
GITHUB_TOKEN=
GITHUB_OWNER=MY_GITHUB_OWNER
GITHUB_REPO=MY_SKILLS_REPO
GITHUB_BRANCH=main

# ─── LLM (skill generation) ───────────────────────────────────────────────────
# Anthropic API key. When set, /app/create uses Claude to author the SKILL.md.
# When absent, the deterministic template generator (lib/skill/generator.ts) is used
# so the app is fully functional with zero external dependencies.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-fable-5

# ─── Supabase (persistence) ───────────────────────────────────────────────────
# When absent, the app reads/writes the in-memory mock store (lib/mock-data.ts).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
